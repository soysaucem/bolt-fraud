{
  "name": "@bolt-fraud/adapter-express",
  "version": "0.2.0",
  "description": "Express middleware adapter for bolt-fraud anti-bot verification",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@bolt-fraud/server": "^0.1.0",
    "express": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@bolt-fraud/server": "^0.1.0",
    "@types/express": "^4.17.21",
    "express": "^4.18.2",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
